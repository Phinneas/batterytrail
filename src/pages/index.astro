---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Sidebar from "../components/Sidebar.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getBlogPosts } from "../lib/sonicjs";

const allPosts = await getBlogPosts();
const featuredPost = allPosts.find((post) => post.data.featured);
const regularPosts = allPosts
	.filter((post) => !post.data.featured)
	.sort((a, b) => new Date(b.data.publishedAt).valueOf() - new Date(a.data.publishedAt).valueOf());

const formatDate = (dateStr: string) => {
	return new Date(dateStr).toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
};
---

<Layout title="BatteryTrail — RV, Ebike & Battery Guides" description="Expert guides on RV batteries, ebike batteries, and off-grid power systems for adventurers.">
	<Header />
	<Hero />

	<main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
		<div class="flex flex-col lg:flex-row gap-12">
			<!-- Main Content -->
			<div class="lg:w-2/3">
				<div class="flex items-center justify-between mb-8">
					<h2
						class="text-2xl font-bold text-slate-900 dark:text-white border-l-4 border-primary pl-3"
					>
						Featured Articles
					</h2>
					<a
						class="text-sm text-primary hover:text-cyan-300 font-medium flex items-center"
						href="/archive"
					>
						View All <svg
							xmlns="http://www.w3.org/2000/svg"
							width="14"
							height="14"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="ml-1"
						>
							<path d="M5 12h14"></path>
							<path d="m12 5 7 7-7 7"></path>
						</svg>
					</a>
				</div>

				<!-- Featured Post -->
				{
					featuredPost && (
						<ArticleCard
							featured={true}
							title={featuredPost.data.title}
							description={featuredPost.data.excerpt}
							image={featuredPost.data.featuredImage}
							category={featuredPost.data.category}
							author={featuredPost.data.author}
							date={formatDate(featuredPost.data.publishedAt)}
							readTime={featuredPost.data.readTime}
							slug={featuredPost.data.slug}
						/>
					)
				}

				<!-- Regular Posts Grid -->
				<div class="grid md:grid-cols-2 gap-6">
					{
						regularPosts.map((post) => (
							<ArticleCard
								title={post.data.title}
								description={post.data.excerpt}
								image={post.data.featuredImage}
								category={post.data.category}
								author={post.data.author}
								date={formatDate(post.data.publishedAt)}
								readTime={post.data.readTime}
								slug={post.data.slug}
							/>
						))
					}
				</div>

				<div class="mt-12 text-center">
					<a
						href="/archive"
						class="inline-block px-6 py-2 rounded-full border border-slate-300 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:border-primary hover:text-primary dark:hover:border-primary dark:hover:text-primary transition-all text-sm font-medium"
					>
						View All Articles
					</a>
				</div>
			</div>

			<!-- Sidebar -->
			<Sidebar />
		</div>
	</main>

	<Footer />
</Layout>
