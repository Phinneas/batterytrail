---
import { getBlogPosts, getBlogPostBySlug, parseTags, type BlogPost } from "../../lib/sonicjs";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostSidebarLeft from "../../components/PostSidebarLeft.astro";
import PostSidebarRight from "../../components/PostSidebarRight.astro";

export async function getStaticPaths() {
    const posts = await getBlogPosts();
    return posts.map((post) => ({
        params: { slug: post.data.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const tags = parseTags(post.data.tags);

// Get related posts
const allPosts = await getBlogPosts();
const relatedPosts = allPosts
    .filter((p) => p.id !== post.id)
    .map((p) => {
        let score = 0;
        const pTags = parseTags(p.data.tags);
        if (pTags.length && tags.length) {
            const sharedTags = pTags.filter((tag: string) =>
                tags.includes(tag),
            );
            score += sharedTags.length * 5;
        }
        if (p.data.category === post.data.category) {
            score += 3;
        }
        return { post: p, score };
    })
    .filter((item) => item.score > 0)
    .sort((a, b) => b.score - a.score || b.post.created_at - a.post.created_at)
    .slice(0, 3);

// Fallback to latest posts if no related posts found
let finalRelatedPosts = relatedPosts.map((item) => item.post);
if (finalRelatedPosts.length < 3) {
    const fallbackPosts = allPosts
        .filter(
            (p) =>
                p.id !== post.id &&
                !finalRelatedPosts.find((rp) => rp.id === p.id),
        )
        .sort((a, b) => b.created_at - a.created_at)
        .slice(0, 3 - finalRelatedPosts.length);
    finalRelatedPosts = [...finalRelatedPosts, ...fallbackPosts];
}

const formattedRelatedPosts = finalRelatedPosts.map((p) => {
    const _rd = p.data.publishedAt;
    const _d = (_rd && !isNaN(new Date(_rd).getTime())) ? new Date(_rd) : new Date(p.created_at);
    return {
    title: p.data.title,
    date: _d.toLocaleDateString("en-US", {
        month: "short",
        day: "2-digit",
        year: "numeric",
    }),
    readTime: p.data.readTime,
    image: p.data.featuredImage,
    slug: p.data.slug,
    };
});

// Extract headings from HTML content for TOC
const headingRegex = /<h([2-3])[^>]*id=["']([^"']*)["'][^>]*>(.*?)<\/h[2-3]>/g;
const headings: { depth: number; slug: string; text: string }[] = [];
let match;
while ((match = headingRegex.exec(post.data.content)) !== null) {
    headings.push({
        depth: parseInt(match[1]),
        slug: match[2],
        text: match[3].replace(/<[^>]+>/g, ''),
    });
}

// Guard: if publishedAt is missing/invalid (can happen when a post is edited
// through the CMS UI without re-entering the date), fall back to created_at.
const _rawDate = post.data.publishedAt;
const pubDate = (_rawDate && !isNaN(new Date(_rawDate).getTime()))
  ? new Date(_rawDate)
  : new Date(post.created_at);

const formatDate = (date: Date) => {
    return date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
    });
};
---

<Layout
    title={`${post.data.title} | BatteryTrail`}
    description={post.data.excerpt}
    image={post.data.featuredImage}
    article={{
        publishedTime: pubDate.toISOString(),
        author: post.data.author,
        category: post.data.category,
        tags: tags,
        slug: post.data.slug,
    }}
>
    <Header />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": post.data.title,
        "description": post.data.excerpt,
        "image": post.data.featuredImage,
        "datePublished": pubDate.toISOString(),
        "author": {
            "@type": "Organization",
            "name": post.data.author,
            "url": "https://www.batterytrail.com"
        },
        "publisher": {
            "@type": "Organization",
            "name": "BatteryTrail",
            "url": "https://www.batterytrail.com",
            "logo": {
                "@type": "ImageObject",
                "url": "https://www.batterytrail.com/favicon.svg"
            }
        },
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": new URL(`/posts/${post.data.slug}`, Astro.site).toString()
        },
        ...(tags.length ? {"keywords": tags.join(", ")} : {})
    })} />

    <main class="relative flex min-h-screen flex-col">
        <div
            class="w-full max-w-[1440px] mx-auto flex-1 px-4 sm:px-6 lg:px-8 py-10"
        >
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 relative">
                <!-- Left Sidebar -->
                <PostSidebarLeft slug={post.data.slug} />

                <!-- Article Content -->
                <article class="col-span-1 lg:col-span-8 w-full">
                    <div class="mb-10">
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span
                                class="inline-flex items-center rounded-lg bg-primary/10 px-3 py-1 text-sm font-medium text-primary ring-1 ring-inset ring-primary/20"
                            >
                                {post.data.category}
                            </span>
                        </div>

                        <h1
                            class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.15] mb-6"
                        >
                            {post.data.title}
                        </h1>

                        <div
                            class="flex items-center gap-4 py-4 border-b border-slate-200 dark:border-[#224249]"
                        >
                            <div class="flex flex-col">
                                <span
                                    class="text-sm font-bold text-slate-900 dark:text-white"
                                    >{post.data.author}</span
                                >
                                <div
                                    class="flex items-center gap-2 text-sm text-slate-500 dark:text-[#90c1cb]"
                                >
                                    <span>{formatDate(pubDate)}</span>
                                    <span>•</span>
                                    <span>{post.data.readTime}</span>
                                </div>
                            </div>
                            <div class="ml-auto flex gap-2">
                                <button
                                    class="rounded-full p-2 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors lg:hidden"
                                    aria-label="Share"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path
                                            d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"
                                        ></path>
                                        <polyline points="16 6 12 2 8 6"
                                        ></polyline>
                                        <line x1="12" x2="12" y1="2" y2="15"
                                        ></line>
                                    </svg>
                                </button>
                                <button
                                    class="rounded-full p-2 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors lg:hidden"
                                    aria-label="Bookmark"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path
                                            d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"
                                        ></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div
                        class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl"
                        set:html={post.data.content}
                    />

                    <div
                        class="mt-12 pt-8 border-t border-slate-200 dark:border-[#224249]"
                    >
                        <div
                            class="flex flex-col sm:flex-row justify-between items-center gap-6"
                        >
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="text-sm text-slate-500 dark:text-slate-400 mr-2 self-center"
                                    >Tags:</span
                                >
                                {
                                    tags.map((tag: string) => (
                                        <span class="px-3 py-1 rounded-full bg-slate-100 dark:bg-surface-dark text-xs font-medium text-slate-600 dark:text-slate-300 hover:bg-primary/20 hover:text-primary transition-colors cursor-default">
                                            #{tag}
                                        </span>
                                    ))
                                }
                            </div>
                            <!-- Social Share -->
                            <div class="flex items-center gap-4">
                                <span
                                    class="text-sm font-medium text-slate-900 dark:text-white"
                                    >Share Article</span
                                >
                                <div class="flex gap-2">
                                    <button
                                        class="size-8 flex items-center justify-center rounded-full bg-slate-100 dark:bg-surface-dark text-slate-600 dark:text-slate-300 hover:bg-[#1da1f2] hover:text-white transition-all"
                                    >
                                        <svg
                                            class="w-4 h-4"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                            ><path
                                                d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"
                                            ></path></svg
                                        >
                                    </button>
                                    <button
                                        class="size-8 flex items-center justify-center rounded-full bg-slate-100 dark:bg-surface-dark text-slate-600 dark:text-slate-300 hover:bg-[#0a66c2] hover:text-white transition-all"
                                    >
                                        <svg
                                            class="w-4 h-4"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                            ><path
                                                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                                            ></path></svg
                                        >
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </article>

                <!-- Right Sidebar -->
                <div class="hidden lg:block lg:col-span-3">
                    <PostSidebarRight
                        headings={headings}
                        relatedPosts={formattedRelatedPosts}
                    />
                </div>
            </div>
        </div>
    </main>

    <Footer />

    <script>
        // Copy to clipboard functionality
        const copyButtons = document.querySelectorAll(".copy-button");
        copyButtons.forEach((button) => {
            button.addEventListener("click", async () => {
                const wrapper = button.closest(".code-block-wrapper");
                const codeElement = wrapper?.querySelector("pre");
                const code = codeElement?.innerText || "";

                const textSpan = button.querySelector("span:last-child");
                const iconElement =
                    button.querySelector(".material-symbols-outlined") ||
                    button.querySelector("svg") ||
                    button.querySelector(".icon-container");

                if (code && textSpan) {
                    try {
                        await navigator.clipboard.writeText(code);
                        if (textSpan) textSpan.textContent = "Copied!";
                        if (iconElement) {
                            iconElement.innerHTML = `
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            `;
                        }
                        button.classList.add("text-primary");
                        setTimeout(() => {
                            if (textSpan) textSpan.textContent = "Copy";
                            if (iconElement) {
                                iconElement.innerHTML = `
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>
                                `;
                            }
                            button.classList.remove("text-primary");
                        }, 2000);
                    } catch (err) {
                        console.error("Failed to copy text: ", err);
                    }
                }
            });
        });
    </script>
</Layout>
