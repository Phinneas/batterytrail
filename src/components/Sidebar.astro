---
import { getBlogPosts } from "../lib/sonicjs";

const allPosts = await getBlogPosts();

// Randomly select 3 posts for Most Popular on each render
const shuffled = [...allPosts].sort(() => Math.random() - 0.5);
const popularPosts = shuffled.slice(0, 3);
---

<aside class="lg:w-1/3 space-y-8">
    <!-- About BatteryTrail -->
    <div
        class="bg-card-light dark:bg-card-dark rounded-xl p-6 border border-slate-200 dark:border-white/5 shadow-sm"
    >
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">
            About BatteryTrail
        </h3>
        <p
            class="text-slate-600 dark:text-slate-400 text-sm mb-4 leading-relaxed"
        >
            BatteryTrail covers everything about mobile power — from RV battery
            setups and lithium upgrades to ebike battery guides and comparisons.
        </p>
        <div class="flex gap-3">
            <a
                class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white transition-colors"
                href="#"
            >
                <span class="text-xs font-bold">X</span>
            </a>
            <a
                class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white transition-colors"
                href="#"
            >
                <span class="text-xs font-bold">Gh</span>
            </a>
            <a
                class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white transition-colors"
                href="#"
            >
                <span class="text-xs font-bold">In</span>
            </a>
        </div>
    </div>

    <!-- Most Popular Posts -->
    <div
        class="bg-card-light dark:bg-card-dark rounded-xl p-6 border border-slate-200 dark:border-white/5 shadow-sm"
    >
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">
            Most Popular Posts
        </h3>
        <div class="space-y-4">
            {
                popularPosts.map((post, index) => (
                    <>
                        <a class="group block" href={`/posts/${post.data.slug}`}>
                            <span class="text-primary text-xs font-bold uppercase mb-1 block">
                                {post.data.category}
                            </span>
                            <h4 class="text-sm font-semibold text-slate-800 dark:text-slate-200 group-hover:text-primary transition-colors leading-snug">
                                {post.data.title}
                            </h4>
                        </a>
                        {index < 2 && (
                            <div class="h-px bg-slate-100 dark:bg-slate-800" />
                        )}
                    </>
                ))
            }
        </div>
    </div>

    <!-- Newsletter -->
    <div
        class="relative bg-gradient-to-br from-cyan-900 to-background-dark rounded-xl p-6 border border-primary/20 shadow-lg overflow-hidden"
    >
        <div
            class="absolute -top-10 -right-10 w-32 h-32 bg-primary/20 rounded-full blur-3xl"
        >
        </div>
        <h3 class="relative text-lg font-bold text-white mb-2">
            Battery & Power Tips
        </h3>
        <p class="relative text-slate-300 text-sm mb-4">
            Get guides, comparisons, and gear reviews for RV batteries and ebikes — delivered free.
        </p>
        <form class="relative space-y-3">
            <input
                class="w-full bg-black/30 border border-white/10 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-primary placeholder-slate-500"
                placeholder="email@example.com"
                type="email"
            />
            <button
                class="w-full bg-primary hover:bg-cyan-400 text-background-dark font-bold py-2 rounded text-sm transition-colors shadow-lg shadow-primary/20"
            >
                Subscribe
            </button>
        </form>
    </div>
</aside>
